# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Whisper (large-v3 recomendado para português)
# WHISPER_MODEL=large-v3

# Idioma (pt = português)
# WHISPER_LANGUAGE=pt

# Número de speakers (deixe comentado para detecção automática)
# NUM_SPEAKERS=2
# MIN_SPEAKERS=2
# MAX_SPEAKERS=4

# Diretórios (padrão: data/audio e data/output relativos ao projeto)
# AUDIO_DIR=/caminho/para/audios
# OUTPUT_DIR=/caminho/para/saida
